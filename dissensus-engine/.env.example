# Dissensus Engine — Environment Variables
# Copy to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production

# API Keys (optional — if set, users don't need to enter keys)
# Set at least one for VPS deployment so visitors can debate without keys

# DeepSeek (recommended — cheapest, ~$0.008/debate)
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Google Gemini (free tier available)
# GOOGLE_API_KEY=AIza...
# or
# GEMINI_API_KEY=AIza...

# OpenAI (premium quality)
# OPENAI_API_KEY=sk-your-openai-key
