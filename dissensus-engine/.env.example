# Dissensus Engine — Environment Variables
# Copy to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production

# Trust reverse proxy (nginx). Set TRUST_PROXY=0 only if no proxy in front of Node.
# TRUST_PROXY_HOPS=1

# Debate of the Day — timezone for "today" (default: UTC)
# Examples: America/New_York, Europe/London, UTC
# DEBATE_OF_THE_DAY_TZ=UTC

# API Keys — Add any providers you want. Users can also enter their own keys.
# If you set a key here, visitors can use that provider without entering a key.
# Users can override with their own key to use their quota instead.

# DeepSeek (cheapest, ~$0.008/debate)
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Google Gemini (free tier available at aistudio.google.com)
# GOOGLE_API_KEY=AIza...
# or
# GEMINI_API_KEY=AIza...

# OpenAI (premium quality)
# OPENAI_API_KEY=sk-your-openai-key

# Simulated staking — require wallet + daily tier limits for debates (default: off)
# STAKING_ENFORCE=1

# Solana — on-chain $DISS balance (server-side RPC; use Helius/QuickNode in prod)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# DISS_TOKEN_MINT=G1Nb4BSnyQd7vxzicxmnj1DgxitH2BTP7QJ3FJXF
# SOLANA_CLUSTER=mainnet-beta

# Future: on-chain stake program (leave unset until deployed)
# DISS_STAKING_PROGRAM_ID=
